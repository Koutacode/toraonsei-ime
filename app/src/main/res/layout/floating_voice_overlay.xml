<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="68dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_floating_bubble"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/floatingStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="待機中"
            android:textColor="#B0BEC5"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/floatingAppContextText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#80CBC4"
            android:textSize="10sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/floatingPreviewEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@android:color/transparent"
            android:hint="ここに認識結果が表示されます（編集可能）"
            android:textColor="#FFFFFF"
            android:textColorHint="#607D8B"
            android:textSize="15sp"
            android:minLines="2"
            android:maxLines="8"
            android:gravity="top|start"
            android:inputType="textMultiLine|textAutoCorrect"
            android:autofillHints="" />

        <LinearLayout
            android:id="@+id/floatingActionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/floatingInsertButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:text="挿入"
                android:textSize="13sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/floatingCopyButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:text="コピー"
                android:textSize="13sp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/floatingUndoButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:minWidth="0dp"
                android:text="戻す"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/floatingClearButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:minWidth="0dp"
                android:text="消去"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/floatingMicButton"
        style="@style/Widget.Material3.Button"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:backgroundTint="#00897B"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:text="🎤"
        android:textSize="26sp"
        app:cornerRadius="30dp"
        app:iconPadding="0dp" />

</FrameLayout>
