<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="トラ音声入力"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="話して → 整形 → 挿入。どのアプリの入力欄にも使えます。" />

        <!-- Step 1: Permissions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ステップ1: 権限の許可"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/requestPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="マイク/通知権限を許可" />

        <Button
            android:id="@+id/openOverlayPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="オーバーレイ権限を許可（他アプリの上に表示）" />

        <Button
            android:id="@+id/openAccessibilitySettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="テキスト挿入サービスを有効化" />

        <!-- Step 2: Scene mode -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ステップ2: トーン設定"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="入力先に合わせた文体に整形します。LINE等のSNSでは文末「。」を付けません。"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/sceneModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/sceneModeMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="会話 (SNS)" />

            <RadioButton
                android:id="@+id/sceneModeWork"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="仕事 (敬語)" />
        </RadioGroup>

        <!-- Step 3: Model -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ステップ3: AIモデル"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/localLlmStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="状態: 確認中..." />

        <TextView
            android:id="@+id/localLlmPathText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textSize="12sp"
            android:textColor="#64748B" />

        <Button
            android:id="@+id/importLlmModelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Qwen 2.5 3B を自動取得（Wi-Fi推奨）" />

        <!-- Step 4: ASR model (optional) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ステップ4: 高精度ASR（任意）"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/asrModelStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="状態: システムASR使用中（デフォルト）" />

        <Button
            android:id="@+id/importAsrModelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Sherpa-ONNX ASRモデルを配置（オフライン高精度）" />

        <!-- Step 5: Dictionary -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ステップ5: ユーザー辞書"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="読み（かな）→ 書き（変換後）を登録。固有名詞や専門用語の誤変換を直します。"
            android:textSize="13sp" />

        <Button
            android:id="@+id/openDictionaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="ユーザー辞書を開く" />

        <!-- Floating launcher -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="フローティング音声入力"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/floatingStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="状態: 停止中" />

        <Button
            android:id="@+id/startFloatingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="フローティング音声入力を起動" />

        <Button
            android:id="@+id/stopFloatingButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="フローティング音声入力を停止" />

        <!-- Lock -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="アプリロック"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/lockButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="再ロック（パスコード画面へ戻す）" />

        <!-- Privacy -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="プライバシー"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#64748B"
            android:text="・音声入力はマイクボタン押下時のみ作動します（常時録音なし）\n・整形はすべて端末内（Gemma on llama.cpp）\n・ユーザー辞書と設定は端末内保存" />

    </LinearLayout>
</ScrollView>
